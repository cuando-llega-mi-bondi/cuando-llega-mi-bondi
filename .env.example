# Frontend (bondi-mdp / Next.js).
# Copiar a .env.local y completar. Nunca commitear .env.local.

# URL pública del backend bondi-api (cloudflared a la PC).
# En dev local podés usar http://localhost:4000.
NEXT_PUBLIC_BONDI_API_URL=

# OSRM proxy (ya lo levantás con docker-compose en infrastructure/osrm).
NEXT_PUBLIC_OSRM_URL=

# Vapid public key (para web-push subscribe en el browser). Es la misma que
# usa el server pero la versión "public" — sí va al cliente.
NEXT_PUBLIC_VAPID_PUBLIC=
