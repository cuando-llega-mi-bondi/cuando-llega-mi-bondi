# Copiar a server/.env.local y completar con valores reales.
# Nunca commitear .env.local — ya está en .gitignore.

# --- Postgres (pg-aeterna) -------------------------------------------------
# Cadena de conexión completa. Ver db/README.md para schema.
DATABASE_URL=

# --- Auth -----------------------------------------------------------------
# Secret HS256 compartido con aeterna. CRITICAL: nunca exponer; cualquier
# cambio invalida todos los JWT en circulación.
JWT_SECRET=
# Nombre de la cookie httpOnly que setea el server tras login.
AUTH_COOKIE_NAME=auth_token
# Dominio para la cookie; requiere SameSite=None+Secure si el frontend está en
# otro dominio (ej. ".aeterna.red").
AUTH_COOKIE_DOMAIN=
# Vida útil del JWT en segundos (default 7 días).
AUTH_TOKEN_TTL_SECONDS=604800

# --- CORS -----------------------------------------------------------------
# Origins permitidos separados por coma (ej. "https://bondimdp.com.ar,http://localhost:3000").
ALLOWED_ORIGINS=

# --- Web Push (VAPID) -----------------------------------------------------
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=

# --- API Muni (Mar del Plata) --------------------------------------------
# Dos paths excluyentes para hablar con la app oficial. Si está MGP_RSA_PUBKEY
# +MGP_SHARED_KEY se usa el path "direct" (replica el WebView Cordova firmando
# con RSA). Si solo está MGP_PROXY_URL, se usa el proxy externo (Termux/Oracle).
# Si no está ninguno, el endpoint /lineas/:linea/arribos devuelve "muni_unavailable".
MGP_RSA_PUBKEY=
MGP_SHARED_KEY=
MGP_PROXY_URL=

# --- Server ---------------------------------------------------------------
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
