# Server-side env vars para el container bondi-front.
# Copiar a infrastructure/frontend/.env.local y completar.
# (Las NEXT_PUBLIC_* se hornean en el build, ver docker-compose.yml.)

# Direct path a la muni (token APK V670). Ambas requeridas para evitar caer al proxy.
MGP_RSA_PUBKEY=
MGP_SHARED_KEY=

# Fallback proxies (Termux y/o Oracle). Opcionales si MGP_RSA_PUBKEY+MGP_SHARED_KEY andan.
MGP_PROXY_URL=
MGP_PROXY_TOKEN=
MGP_ORACLE_URL=
MGP_ORACLE_TOKEN=

# Override del path del dump si está fuera de /app/data (no debería).
# STATIC_REFERENCE_DUMP_PATH=
